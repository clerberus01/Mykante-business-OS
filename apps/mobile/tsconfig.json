{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mykante/shared/validation/client": ["../../packages/shared/validation/client.ts"],
      "@mykante/shared/*": ["../../packages/shared/*"]
    }
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx", "../../packages/shared/**/*.ts"]
}
