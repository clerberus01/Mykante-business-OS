# App
APP_URL="https://your-production-domain.vercel.app"
VERCEL_URL="your-preview-deployment.vercel.app"
VERCEL_PROJECT_PRODUCTION_URL="your-production-domain.vercel.app"
VERCEL_ORG_ID="your-vercel-org-id"
VERCEL_TEAM_ID="your-vercel-team-id"
VERCEL_PROJECT_ID="your-vercel-project-id"
DISABLE_HMR="false"

# Frontend Supabase
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_ONESIGNAL_APP_ID="your-onesignal-app-id"

# Server-side only. Never prefix these with VITE_ and never read them from src/.
SUPABASE_PROJECT_URL="https://your-project-ref.supabase.co"
SUPABASE_DB_URL="postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Integrations
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="Mykante OS <noreply@your-domain.com>"
ONESIGNAL_APP_ID="your-onesignal-app-id"
ONESIGNAL_REST_API_KEY="your-onesignal-rest-api-key"
ONESIGNAL_API_KEY="your-onesignal-api-key"

# Global API rate limiting. Vercel KV exposes KV_*; Upstash Redis exposes UPSTASH_*.
KV_REST_API_URL="https://your-vercel-kv-or-upstash-url"
KV_REST_API_TOKEN="your-vercel-kv-rest-token"
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"

# Optional Web Push credentials for future non-OneSignal push delivery.
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@your-domain.com"

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN="your-meta-system-user-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_APP_SECRET="your-meta-app-secret"
WHATSAPP_ORGANIZATION_ID="your-default-organization-id-for-webhooks"
