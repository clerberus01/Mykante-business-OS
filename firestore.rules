rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'clerberus@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidClient(data) {
      return data.size() >= 10 && data.size() <= 20 &&
             data.id is string && data.id.size() <= 128 &&
             data.personType in ['Física', 'Jurídica'] &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 255 &&
             data.taxId is string && data.taxId.size() <= 32 &&
             data.email is string && data.email.size() <= 255 &&
             data.status in ['active', 'inactive', 'archived', 'lead'] &&
             data.address is map &&
             data.dueDay is number &&
             data.tags is list &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidTimelineEvent(data) {
      return data.size() >= 7 && data.size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.type in ['email', 'whatsapp', 'note', 'file', 'system'] &&
             data.title is string && data.title.size() <= 255 &&
             data.content is string && data.content.size() <= 10000 &&
             data.createdAt is number &&
             data.createdBy is string;
    }

    function isValidProject(data) {
      return data.size() >= 10 && data.size() <= 12 &&
             data.id is string && data.id.size() <= 128 &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.name is string && data.name.size() <= 255 &&
             data.status in ['draft', 'ongoing', 'paused', 'completed', 'cancelled'] &&
             data.startDate is number &&
             data.deadline is number &&
             data.budget is number &&
             data.paymentStatus in ['paid', 'pending', 'overdue'] &&
             data.progress is number &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidMilestone(data) {
      return data.size() == 6 &&
             data.id is string &&
             data.projectId is string &&
             data.title is string &&
             data.order is number &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is number;
    }

    function isValidTask(data) {
      return data.size() >= 9 && data.size() <= 12 &&
             data.id is string && data.id.size() <= 128 &&
             data.projectId is string &&
             data.milestoneId is string &&
             data.title is string && data.title.size() <= 500 &&
             data.status in ['todo', 'doing', 'done'] &&
             data.priority in ['low', 'medium', 'high', 'urgent'] &&
             data.responsible is string &&
             data.checklist is list &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    // --- Match Rules ---

    match /clients/{clientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && isValidClient(incoming()) && incoming().id == clientId;
      allow update: if isAdmin() && isValidClient(incoming()) && 
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();

      match /events/{eventId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin() && isValidTimelineEvent(incoming()) && incoming().id == eventId && incoming().clientId == clientId;
        allow delete: if isAdmin();
      }
    }

    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && isValidProject(incoming()) && incoming().id == projectId;
      allow update: if (isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'updatedAt']))) &&
                    isValidProject(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();

      match /milestones/{milestoneId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      match /tasks/{taskId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin();
        allow update: if (isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'checklist']))) && 
                      isValidTask(incoming()) &&
                      incoming().id == existing().id &&
                      incoming().createdAt == existing().createdAt;
        allow delete: if isAdmin();
      }

      match /activity/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
